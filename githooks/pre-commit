#!/bin/bash
# Pre-commit syntax + truncation guard.
#
# Cowork-on-Windows write semantics occasionally truncate a file mid-line near
# the end (mid-Edit-tool flush, killed Rscript holding a file handle, session
# ending mid-write). Truncated R / JS / JSON files always parse-fail. Catching
# them here means a corrupted file never lands on a remote.
#
# This version batches parse checks per language to avoid spawning a fresh
# interpreter per file. With ~1900 staged JSON files, the per-file loop took
# 2-3 minutes; the batched loop takes seconds.
#
# To skip in genuine emergencies: git commit --no-verify
set -e

fail() { echo "PRE-COMMIT FAIL: $1"; exit 1; }

# Cache the staged file list once so we don't re-run git diff per language.
CHANGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$CHANGED" ] && { echo "pre-commit: OK (no staged changes)"; exit 0; }

# Filter helper: select files matching a regex AND that exist on disk.
filter_existing() {
  local pattern=$1
  printf '%s\n' "$CHANGED" | grep -E "$pattern" 2>/dev/null | while IFS= read -r f; do
    [ -f "$f" ] && printf '%s\n' "$f"
  done
}

# R: parse each R file in its own Rscript invocation. Tried batching via
# readLines("stdin"), but Rscript on Windows segfaults reading stdin via the
# Git-Bash mintty pipe. Per-file is slower (one R startup per file) but
# robust. R files in a typical commit are few (<10), so the wall-clock cost
# is bounded; the JSON batching below handles the data-regen case where
# 1900 files would have killed us.
if command -v Rscript >/dev/null 2>&1; then
  R_FILES=$(filter_existing '\.[Rr]$')
  if [ -n "$R_FILES" ]; then
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      Rscript --vanilla -e "tryCatch(invisible(parse(file = '$f')), error = function(e) { cat(conditionMessage(e), '\n', file = stderr()); quit(status = 1L) })" \
        || fail "R parse failed: $f"
    done <<< "$R_FILES"
  fi
fi

# JavaScript: node --check is per-file, but JS changes are usually few. Keep
# the per-file loop rather than reimplementing a parser.
if command -v node >/dev/null 2>&1; then
  JS_FILES=$(filter_existing '\.(js|mjs|cjs)$')
  if [ -n "$JS_FILES" ]; then
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      node --check "$f" || fail "JS parse failed: $f"
    done <<< "$JS_FILES"
  fi
fi

# Detect Python interpreter.
if command -v python >/dev/null 2>&1; then
  PY=python
elif command -v python3 >/dev/null 2>&1; then
  PY=python3
else
  PY=
fi

# JSON: batch via one python invocation. Reads file paths from stdin.
if [ -n "$PY" ]; then
  JSON_FILES=$(filter_existing '\.json$')
  if [ -n "$JSON_FILES" ]; then
    printf '%s\n' "$JSON_FILES" | "$PY" -c '
import json, sys
failed = 0
for line in sys.stdin:
    path = line.rstrip("\r\n")
    if not path:
        continue
    try:
        with open(path, "r", encoding="utf-8") as f:
            json.load(f)
    except Exception as e:
        print(f"JSON parse failed: {path}: {e}", file=sys.stderr)
        failed += 1
sys.exit(1 if failed else 0)
' || fail "JSON parse failed (see stderr above)"
  fi
fi

# YAML: same batching pattern.
if [ -n "$PY" ]; then
  YAML_FILES=$(filter_existing '\.ya?ml$')
  if [ -n "$YAML_FILES" ]; then
    printf '%s\n' "$YAML_FILES" | "$PY" -c '
import yaml, sys
failed = 0
for line in sys.stdin:
    path = line.rstrip("\r\n")
    if not path:
        continue
    try:
        with open(path, "r", encoding="utf-8") as f:
            yaml.safe_load(f)
    except Exception as e:
        print(f"YAML parse failed: {path}: {e}", file=sys.stderr)
        failed += 1
sys.exit(1 if failed else 0)
' || fail "YAML parse failed (see stderr above)"
  fi
fi

# Trailing-newline check: a file whose last line lacks a terminating newline
# is the classic Cowork-truncation fingerprint. tail -c 1 is tiny and fast,
# but iterating in shell is still the bottleneck after batching the parsers.
# Acceptable for now since the average commit doesnt regen 1900 data files.
TRAILING_FILES=$(filter_existing '\.(R|r|js|mjs|cjs|json|ya?ml|html|css|md|py)$')
if [ -n "$TRAILING_FILES" ]; then
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ -n "$(tail -c 1 "$f")" ]; then
      fail "File ends without a trailing newline (truncation fingerprint): $f"
    fi
  done <<< "$TRAILING_FILES"
fi

echo "pre-commit: OK"
